{
    "name": "lis-gateway",
    "version": "1.0.0",
    "description": "Bridge between local instruments and Cloud LIS",
    "main": "dist/index.js",
    "scripts": {
        "start": "ts-node src/index.ts",
        "build": "tsc",
        "build:service": "npm run build",
        "build:service:pkg": "npm run build && pkg dist/index.js --targets node18-win-x64 --output dist/bin/lis-gateway-agent.exe",
        "service:install": "powershell -ExecutionPolicy Bypass -File scripts/install-service.ps1",
        "service:uninstall": "powershell -ExecutionPolicy Bypass -File scripts/uninstall-service.ps1"
    },
    "dependencies": {
        "axios": "^1.6.0",
        "better-sqlite3": "^12.6.2",
        "dotenv": "^16.3.1",
        "serialport": "^12.0.0"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^20.10.0",
        "pkg": "^5.8.1",
        "ts-node": "^10.9.1",
        "typescript": "^5.3.2"
    }
}