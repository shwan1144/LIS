LIS_API_URL=http://your-cloud-lis.com/api
LIS_API_KEY=your_secret_api_key
GATEWAY_ID=lab-gateway-01
FORWARD_TIMEOUT_MS=8000

# Offline queue settings (SQLite outbox)
QUEUE_DB_PATH=./data/gateway-queue.db
QUEUE_RETENTION_DAYS=7
QUEUE_BATCH_SIZE=50
QUEUE_RETRY_BASE_MS=2000
QUEUE_RETRY_MAX_MS=300000
QUEUE_RETRY_JITTER_PERCENT=20
DISPATCH_INTERVAL_MS=1000
CLEANUP_INTERVAL_MS=60000

# Medonic M51 (TCP)
MEDONIC_PORT=5600
MEDONIC_ID=replace-with-instrument-id-from-cloud

# Cobas C111 (Serial)
COBAS_C111_PORT=COM1
COBAS_C111_BAUD=9600
COBAS_C111_ID=replace-with-instrument-id-from-cloud

# Cobas E411 (Serial)
COBAS_E411_PORT=COM2
COBAS_E411_BAUD=9600
COBAS_E411_ID=replace-with-instrument-id-from-cloud
