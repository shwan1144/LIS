LIS_API_URL=http://your-cloud-lis.com/api
FORWARD_TIMEOUT_MS=8000
GATEWAY_VERSION=1.0.0
LOCAL_API_PORT=17881

# Offline queue settings (SQLite outbox)
# If unset, queue DB defaults to %ProgramData%\LISGateway\data\gateway-queue.db
QUEUE_DB_PATH=
QUEUE_RETENTION_DAYS=7
QUEUE_MAX_BYTES=2147483648
QUEUE_BATCH_SIZE=50
QUEUE_RETRY_BASE_MS=2000
QUEUE_RETRY_MAX_MS=300000
QUEUE_RETRY_JITTER_PERCENT=20
DISPATCH_INTERVAL_MS=1000
CLEANUP_INTERVAL_MS=60000

# Cloud sync intervals (seconds)
GATEWAY_CONFIG_POLL_SEC=60
GATEWAY_HEARTBEAT_SEC=30

# Gateway auth/token policy
GATEWAY_ACCESS_TTL_SEC=3600
GATEWAY_REFRESH_TTL_DAYS=30
GATEWAY_ACTIVATION_TTL_MIN=1440
GATEWAY_ACTIVATION_PEPPER=change_me_in_production

# Optional runtime override root (defaults to %ProgramData%\LISGateway)
LIS_GATEWAY_HOME=
