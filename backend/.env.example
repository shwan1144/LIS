PORT=3000
# Preferred on Railway (single variable from PostgreSQL service)
DATABASE_URL=

# Local database variables (used when DATABASE_URL is empty)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=1111
DB_DATABASE=lis

# Schema + seed behavior
DB_SYNC=true
SEED_SYNC=false
AUTO_SEED_ON_BOOT=false

JWT_SECRET=change-this-in-production
JWT_ACCESS_TTL=900
PLATFORM_JWT_SECRET=change-this-platform-secret
PLATFORM_JWT_ACCESS_TTL=600
PLATFORM_SESSION_TIMEOUT_MINUTES=10
LAB_PORTAL_BRIDGE_TTL_SECONDS=90
APP_BASE_DOMAIN=yourlis.com
APP_ADMIN_HOST=admin.yourlis.com
PATIENT_LOOKUP_KEYS=nationalId,phone,externalId
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
PLATFORM_SEED_EMAIL=superadmin@lis.local
PLATFORM_SEED_PASSWORD=password
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://lab01.localhost:5174,http://admin.localhost:5174

# Auth brute-force/rate-limit controls (DB-backed via audit_logs)
AUTH_LOGIN_RATE_WINDOW_SECONDS=300
AUTH_LOGIN_RATE_MAX_ATTEMPTS_PER_IP=40
AUTH_LOGIN_FAILED_WINDOW_SECONDS=900
AUTH_LOGIN_FAILED_MAX_PER_IP=10
AUTH_LOGIN_FAILED_MAX_PER_IDENTIFIER=5

# Reports PDF runtime/performance settings
# Leave empty unless using a custom Chromium binary path in container/host.
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=
# Fallback to PDFKit when Playwright rendering fails.
REPORTS_PDF_FALLBACK=true
# Cache generated result PDFs in memory (milliseconds).
REPORTS_PDF_CACHE_TTL_MS=120000
# Max in-memory cached report PDFs.
REPORTS_PDF_CACHE_MAX_ENTRIES=30
# Log report generation timings when total exceeds threshold (milliseconds).
REPORTS_PDF_PERF_LOG_THRESHOLD_MS=500

# QZ Tray request signing
# Use either *_PATH values or inline *_PEM values.
QZ_CERT_PATH=
QZ_PRIVATE_KEY_PATH=
QZ_PRIVATE_KEY_PASSPHRASE=
QZ_CERT_PEM=
QZ_PRIVATE_KEY_PEM=
